# ─────────────────────────────────────────────────────────────────────────────
#  OBED TECH — YouTube API Server  •  Environment Variables
#  Copy this file to .env and fill in your values.
#  All values are OPTIONAL — the server works with zero config.
# ─────────────────────────────────────────────────────────────────────────────

# Port the server listens on (default: 3000)
PORT=3000

# Allowed CORS origin — use * to allow all (default)
# Set to your domain in production: https://myapp.com
ALLOWED_ORIGIN=*

# Rate limiting
RATE_LIMIT_MAX=100        # Max requests per IP per window
RATE_LIMIT_WINDOW=60000   # Window in milliseconds (60000 = 1 minute)

# ─────────────────────────────────────────────────────────────────────────────
#  NOTE: This API does NOT require a YouTube API key.
# ─────────────────────────────────────────────────────────────────────────────
